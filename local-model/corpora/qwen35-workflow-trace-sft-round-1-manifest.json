      "description": "Broad open reasoning data to avoid overfitting on one proprietary teacher style."
    },
    {
      "id": "chat_quality",
      "target_weight": 0.25,
      "description": "Single-turn helpfulness and tone quality data to protect general instruction following."
    }
  ],
